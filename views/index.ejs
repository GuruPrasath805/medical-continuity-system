<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="google-site-verification" content="bbHyagUP5lP0GAB7vJGp1FsEI_zOy6jEoX6A0v6ieqs" />
  <title>Medical Continuity Secure Health Records & QR Emergency Access</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/navbar') %>

<!--  HERO (no photo)  -->
<section class="hero-section-full">
  <div class="hero-bg-pattern"></div>
  <div class="container hero-inner">
    <div class="row align-items-center g-5 min-vh-fix">
      <div class="col-lg-6">
        <div class="hero-badge">
          <span class="dot"></span> Trusted Health Record Platform
        </div>
        <h1 class="hero-h1">Your Medical<br>Records. <em>Always<br>with you.</em></h1>
        <p class="hero-sub">Register once, get a personal QR code. Emergency responders see critical info instantly. Doctors access full records with OTP consent only.</p>
        <div class="hero-actions">
          <a href="/patient/register" class="btn btn-hero-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:7px;margin-top:-2px"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Create Health ID Free
          </a>
          <a href="/scan" class="btn btn-hero-ghost">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:6px;margin-top:-2px"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Scan QR
          </a>
        </div>
        <p class="hero-note">No login required to scan &nbsp;.&nbsp; Completely free to register</p>
      </div>

      <!-- Right: mock cards instead of photo -->
      <div class="col-lg-6 d-none d-lg-flex justify-content-center">
        <div class="hero-cards-stack">
          <!-- Health ID preview card -->
          <div class="hc-main">
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px">
              <div style="width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:1.4rem"></div>
              <div>
                <div style="font-weight:700;font-size:1rem;color:white">Health ID Active</div>
                <div style="font-size:0.78rem;opacity:0.55;color:white">Registered & Protected</div>
              </div>
              <div style="margin-left:auto;background:rgba(74,222,128,0.2);border:1px solid rgba(74,222,128,0.4);border-radius:20px;padding:3px 12px;font-size:0.72rem;font-weight:700;color:#86efac">LIVE</div>
            </div>
            <div style="background:rgba(255,255,255,0.08);border-radius:12px;padding:14px 16px;margin-bottom:12px">
              <div style="font-size:0.68rem;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px">Quick Info</div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                <span style="font-size:0.82rem;color:rgba(255,255,255,0.6)">Blood Group</span>
                <span style="font-weight:700;color:#86efac;font-size:1rem;font-family:monospace">B+</span>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center">
                <span style="font-size:0.82rem;color:rgba(255,255,255,0.6)">Emergency Contact</span>
                <span style="font-weight:600;font-size:0.82rem;color:rgba(255,255,255,0.8)">Protected </span>
              </div>
            </div>
            <div style="background:#dc2626;border-radius:10px;padding:11px;text-align:center;font-weight:700;font-size:0.88rem;color:white;cursor:pointer">
               &nbsp;Call Emergency Contact
            </div>
          </div>
          <!-- floating badge -->
          <div class="hc-badge">
            <span style="font-size:1.1rem"></span>
            <div>
              <div style="font-size:0.78rem;font-weight:700;color:var(--text)">OTP Protected</div>
              <div style="font-size:0.68rem;color:var(--muted)">Doctor access only</div>
            </div>
          </div>
          <!-- floating scan badge -->
          <div class="hc-scan">
            <div style="font-size:0.68rem;font-weight:700;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px">QR Ready</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:3px;width:54px">
              <% for(let i=0;i<9;i++){ %>
              <div style="background:<%= ['#16a34a','#16a34a','#16a34a','#16a34a','white','#16a34a','#16a34a','#16a34a','#16a34a'][i] %>;height:16px;border-radius:2px"></div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!--  STATS  -->
<section style="background:white;border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
  <div class="container-fluid px-0">
    <div class="row g-0">
      <div class="col-md-4"><div class="stat-box"><span class="stats-number">30%</span><span class="stats-label">Misdiagnosis from missing records</span></div></div>
      <div class="col-md-4"><div class="stat-box" style="border-left:1px solid var(--border);border-right:1px solid var(--border)"><span class="stats-number">$20B</span><span class="stats-label">Wasted yearly in duplicate tests</span></div></div>
      <div class="col-md-4"><div class="stat-box"><span class="stats-number">45m</span><span class="stats-label">Average delay for critical info</span></div></div>
    </div>
  </div>
</section>

<!--  HOW IT WORKS  -->
<section class="py-5 py-lg-6" id="features">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-eyebrow">How it works</span>
      <h2 class="section-title">Four roles, one seamless system</h2>
      <p class="section-sub">Designed for emergencies. Protected by design.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-3">
        <div class="feature-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h5>Patient Registers</h5>
          <p>Fill your medical history, emergency contact and photo. Get a personal QR health ID card instantly.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="feature-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </div>
          <h5>QR Code Scanned</h5>
          <p>Anyone who scans sees only your emergency contact and blood group - critical details, nothing more.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="feature-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </div>
          <h5>Doctor OTP Access</h5>
          <p>Approved doctors log in, enter patient phone, verify OTP sent to emergency contact and unlock records.</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="feature-card">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h5>Admin Control</h5>
          <p>Admins approve doctors, upload official reports and manage all patient records with full visibility.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!--  STEPS  -->
<section class="py-5" style="background:white;border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-eyebrow">Getting started</span>
      <h2 class="section-title">3 steps to emergency-ready</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-4"><div class="card-box"><div class="step-number">1</div><h5>Register & Get Your QR</h5><p class="text-muted" style="font-size:0.87rem;line-height:1.65">Enter your details, medical history and medicines. Download your personal QR health card.</p></div></div>
      <div class="col-md-4"><div class="card-box"><div class="step-number">2</div><h5>Carry Your QR</h5><p class="text-muted" style="font-size:0.87rem;line-height:1.65">Print it on a wallet card or save on your phone. In any emergency, anyone can scan it instantly.</p></div></div>
      <div class="col-md-4"><div class="card-box"><div class="step-number">3</div><h5>OTP-Protected Access</h5><p class="text-muted" style="font-size:0.87rem;line-height:1.65">Doctors request OTP sent to your emergency contact. Full history unlocked securely with consent.</p></div></div>
    </div>
  </div>
</section>

<!--  CTA  -->
<section class="py-5 py-lg-6">
  <div class="container">
    <div class="cta-block">
      <div class="cta-glow"></div>
      <span class="section-eyebrow" style="color:#86efac">Start today</span>
      <h2 class="cta-h2">Ready to protect your health information?</h2>
      <p class="cta-sub">Create your free Health ID in under 3 minutes. No subscription, no hidden fees.</p>
      <div class="d-flex gap-3 justify-content-center flex-wrap">
        <a href="/patient/register" class="btn btn-outline-light btn-lg">Create Health ID  Free</a>
        <a href="/doctor/register" class="btn btn-lg" style="background:rgba(255,255,255,0.1);color:white;border:1.5px solid rgba(255,255,255,0.2)">Doctor Registration</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
