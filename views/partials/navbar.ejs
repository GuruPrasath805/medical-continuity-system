<script>
  function togglePatientPanel() {
    const panel = document.getElementById('patient-panel');
    panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    if (panel.style.display === 'block') setTimeout(() => document.getElementById('patient-phone-input').focus(), 50);
  }
  function goToPatientDashboard() {
    let phone = document.getElementById('patient-phone-input').value.trim();
    const err = document.getElementById('patient-panel-error');
    if (!phone || phone.length < 7) { err.style.display='block'; err.textContent='Please enter a valid phone number.'; return; }
    // Normalize: remove +91 prefix so lookup matches stored format
    phone = phone.replace(/[\s\-\.]/g,'');
    if (phone.startsWith('+91') && phone.length === 13) phone = phone.slice(3);
    else if (phone.startsWith('91') && phone.length === 12) phone = phone.slice(2);
    err.style.display = 'none';
    window.location.href = '/patient/dashboard/' + encodeURIComponent(phone);
  }
  document.addEventListener('click', function(e) {
    const item = document.getElementById('patient-nav-item');
    if (item && !item.contains(e.target)) { const p = document.getElementById('patient-panel'); if (p) p.style.display='none'; }
  });
  const inp = document.getElementById('patient-phone-input');
  if (inp) inp.addEventListener('keydown', e => { if (e.key==='Enter') goToPatientDashboard(); });
</script>
