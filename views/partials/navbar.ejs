        <li class="nav-item ms-2">
          <div class="position-relative" id="patient-nav-item">
            <button class="btn btn-sm d-flex align-items-center gap-2 fw-600"
                    style="background:var(--green-light);color:var(--green-mid);border:1.5px solid var(--border-green);border-radius:20px;padding:6px 16px;font-weight:600;font-size:0.85rem"
                    onclick="togglePatientPanel()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              My Health ID
            </button>
            <div id="patient-panel"
                 style="display:none;position:absolute;right:0;top:calc(100% + 10px);width:280px;background:white;border-radius:14px;box-shadow:0 8px 40px rgba(0,0,0,0.12);border:1px solid var(--border);padding:1.2rem;z-index:9999">
              <p style="font-size:0.82rem;color:var(--muted);margin-bottom:0.75rem;font-weight:500">Enter your registered phone number to access your health dashboard</p>
              <div class="d-flex gap-2">
                <input type="tel" id="patient-phone-input" class="form-control form-control-sm"
                       placeholder="Phone number" maxlength="15">
                <button class="btn btn-primary btn-sm" onclick="goToPatientDashboard()" style="white-space:nowrap;padding:0 16px">Go</button>
              </div>
              <div id="patient-panel-error" style="display:none;color:var(--danger);font-size:0.78rem;margin-top:0.5rem;font-weight:600"></div>
