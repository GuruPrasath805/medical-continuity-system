<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin Login — Medical Continuity</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background:var(--bg);min-height:100vh;display:flex;align-items:center">
<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-4 col-sm-10">
      <div class="text-center mb-4">
        <div style="width:52px;height:52px;background:var(--green);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3 style="font-family:'DM Serif Display',serif;font-size:1.8rem;margin-bottom:0.25rem">Admin Login</h3>
        <p style="color:var(--muted);font-size:0.88rem">Medical Continuity Admin Panel</p>
      </div>

      <div class="card-box">
        <% if (error) { %><div class="alert-danger mb-3"><%= error %></div><% } %>
        <form method="POST" action="/admin/login">
          <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" name="username" class="form-control" placeholder="Enter username" required autofocus>
          </div>
          <div class="mb-4">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Enter password" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">Sign in to Admin</button>
        </form>
      </div>

      <div class="text-center mt-3">
        <a href="/" style="font-size:0.82rem;color:var(--muted);text-decoration:none">← Back to Home</a>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
