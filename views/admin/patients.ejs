<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin — Patient Records</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body{background:#f8fafc}
    .admin-topbar{background:white;border-bottom:1px solid #e5e7eb;padding:.75rem 0;position:sticky;top:0;z-index:100;box-shadow:0 1px 0 rgba(0,0,0,.04)}
    .page-hero{background:linear-gradient(135deg,#052e16,#14532d 55%,#166534);padding:2rem 0 4rem;color:white;position:relative;overflow:hidden}
    .page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 50%,rgba(74,222,128,.07) 0%,transparent 55%);pointer-events:none}
    .hero-inner{position:relative;z-index:1}
    .pull-up{margin-top:-2.5rem;position:relative;z-index:2}

    /* stats */
    .stat-box{background:white;border:1px solid #e5e7eb;border-radius:16px;padding:1.2rem 1.4rem;box-shadow:0 2px 8px rgba(0,0,0,.05);display:flex;align-items:center;gap:1rem}
    .stat-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
    .stat-num{font-size:1.7rem;font-weight:800;color:#111827;font-family:'JetBrains Mono',monospace;line-height:1}
    .stat-lbl{font-size:.72rem;color:#9ca3af;font-weight:700;margin-top:3px}

    /* search bar */
    .search-bar{background:white;border:1px solid #e5e7eb;border-radius:14px;padding:1rem 1.4rem;box-shadow:0 2px 8px rgba(0,0,0,.04);margin-bottom:1.2rem;display:flex;align-items:center;gap:.75rem}
    .search-input{flex:1;border:none;outline:none;font-size:.88rem;color:#111827;font-family:'DM Sans',sans-serif}
    .search-input::placeholder{color:#c4c9d4}

    /* patient table */
    .patients-table{background:white;border:1px solid #e5e7eb;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04)}
    .pt-thead{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 160px;gap:1rem;padding:.75rem 1.4rem;background:#f8fafc;border-bottom:1px solid #e5e7eb}
    .pt-thead-cell{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:#9ca3af}
    .pt-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 160px;gap:1rem;padding:.9rem 1.4rem;border-bottom:1px solid #f3f4f6;align-items:center;transition:background .15s}
    .pt-row:last-child{border-bottom:none}
    .pt-row:hover{background:#fafafa}
    .pt-avatar{width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid #e5e7eb;flex-shrink:0}
    .pt-avatar-ph{width:36px;height:36px;border-radius:50%;background:#f0fdf4;border:2px solid #bbf7d0;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
    .pt-name-cell{display:flex;align-items:center;gap:10px;min-width:0}
    .pt-name{font-weight:700;font-size:.88rem;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pt-phone{font-size:.72rem;color:#9ca3af;font-family:'JetBrains Mono',monospace;margin-top:1px}
    .blood-pill{display:inline-flex;align-items:center;background:#fef2f2;border:1px solid #fecaca;border-radius:20px;padding:2px 10px;font-size:.72rem;font-weight:800;color:#b91c1c}
    .action-btns{display:flex;gap:.4rem;flex-wrap:wrap}
    .btn-view{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;border-radius:8px;padding:4px 12px;font-size:.75rem;font-weight:700;text-decoration:none;transition:all .15s;white-space:nowrap}
    .btn-view:hover{background:#dcfce7;color:#14532d}
    .btn-report{background:#eff6ff;color:#1e40af;border:1px solid #bfdbfe;border-radius:8px;padding:4px 10px;font-size:.75rem;font-weight:700;text-decoration:none;transition:all .15s;white-space:nowrap}
    .btn-report:hover{background:#dbeafe}
    .btn-remove{background:#fef2f2;color:#b91c1c;border:1px solid #fecaca;border-radius:8px;padding:4px 10px;font-size:.75rem;font-weight:700;cursor:pointer;transition:all .15s;white-space:nowrap}
    .btn-remove:hover{background:#fee2e2}
    .empty-row{padding:3rem;text-align:center;color:#9ca3af;font-size:.88rem}

    @media(max-width:768px){
      .pt-thead{display:none}
      .pt-row{grid-template-columns:1fr;gap:.5rem;padding:1rem 1.2rem}
    }
  </style>
</head>
<body>

<!-- TOP BAR -->
<div class="admin-topbar">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="/" style="font-family:'DM Serif Display',serif;font-size:1.2rem;color:var(--green);text-decoration:none;display:flex;align-items:center;gap:8px">
      <svg width="22" height="22" viewBox="0 0 26 26" fill="none"><rect width="26" height="26" rx="7" fill="#16a34a"/><path d="M13 6v14M6 13h14" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
      Medical Continuity
    </a>
    <div class="d-flex align-items-center gap-3">
      <a href="/admin/patients" class="nav-link" style="font-weight:700;color:var(--green);font-size:.85rem">Patients</a>
      <a href="/admin/doctors"  class="nav-link" style="font-size:.85rem">Doctors</a>
      <a href="/admin/logout" class="btn btn-sm btn-outline-primary" style="border-radius:20px;padding:5px 16px;font-size:.82rem">Sign Out</a>
    </div>
  </div>
</div>

<!-- HERO -->
<div class="page-hero">
  <div class="container hero-inner">
    <div style="font-size:.7rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.4rem">Admin Panel</div>
    <h2 style="font-family:'DM Serif Display',serif;color:white;font-size:2rem;margin:0">Patient Records</h2>
    <p style="color:rgba(255,255,255,.45);font-size:.85rem;margin-top:4px">Manage all registered patients and their medical records</p>
  </div>
</div>

<div class="container pull-up pb-5">

  <!-- STATS -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#f0fdf4">👥</div>
        <div><div class="stat-num"><%= patients.length %></div><div class="stat-lbl">Total Patients</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#eff6ff">🆔</div>
        <div><div class="stat-num"><%= patients.filter(p=>p.qrCode).length %></div><div class="stat-lbl">Active QR IDs</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#fef2f2">📋</div>
        <div><div class="stat-num"><%= patients.reduce((a,p)=>a+(p.reports?p.reports.length:0),0) %></div><div class="stat-lbl">Total Reports</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#fff7ed">💊</div>
        <div><div class="stat-num"><%= patients.reduce((a,p)=>a+(p.medicines?p.medicines.filter(m=>m.name).length:0),0) %></div><div class="stat-lbl">Medicine Records</div></div>
      </div>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="search-bar">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4c9d4" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" class="search-input" id="searchInput" placeholder="Search patients by name or phone..." oninput="filterPatients()">
    <span style="font-size:.75rem;color:#c4c9d4;font-weight:600" id="searchCount"><%= patients.length %> patients</span>
  </div>

  <!-- TABLE -->
  <div class="patients-table">
    <div class="pt-thead">
      <div class="pt-thead-cell">Patient</div>
      <div class="pt-thead-cell">Blood Group</div>
      <div class="pt-thead-cell">Emergency Contact</div>
      <div class="pt-thead-cell">Reports</div>
      <div class="pt-thead-cell">Actions</div>
    </div>

    <div id="patientsList">
    <% if(patients.length === 0){ %>
      <div class="empty-row">
        <div style="font-size:2rem;margin-bottom:8px">👥</div>
        <p style="margin:0">No patients registered yet.</p>
      </div>
    <% } %>
    <% patients.forEach(p => { %>
    <div class="pt-row patient-row" data-name="<%= p.name.toLowerCase() %>" data-phone="<%= p.phone %>">
      <div class="pt-name-cell">
        <% if(p.photo){ %>
          <img src="<%= BASE_URL %><%= p.photo %>" class="pt-avatar" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="pt-avatar-ph" style="display:none">👤</div>
        <% } else { %>
          <div class="pt-avatar-ph">👤</div>
        <% } %>
        <div style="min-width:0">
          <div class="pt-name"><%= p.name %></div>
          <div class="pt-phone"><%= p.phone %></div>
        </div>
      </div>
      <div>
        <% if(p.bloodGroup){ %><span class="blood-pill">🩸 <%= p.bloodGroup %></span><% } else { %><span style="color:#c4c9d4;font-size:.8rem">—</span><% } %>
      </div>
      <div>
        <div style="font-size:.82rem;font-weight:600;color:#374151"><%= p.emergencyName || '—' %></div>
        <div style="font-size:.72rem;color:#9ca3af;font-family:'JetBrains Mono',monospace"><%= p.emergencyContact || '' %></div>
      </div>
      <div>
        <span style="font-size:.82rem;font-weight:700;color:#374151"><%= (p.reports ? p.reports.length : 0) %> files</span>
      </div>
      <div class="action-btns">
        <a href="/admin/patient/<%= p._id %>" class="btn-view">View</a>
        <a href="/admin/patient/<%= p._id %>/add-record" class="btn-report">+ Report</a>
        <form method="POST" action="/admin/patient/<%= p._id %>/delete" style="display:inline" onsubmit="return confirm('Remove <%= p.name %> and all their records permanently?')">
          <button type="submit" class="btn-remove">Remove</button>
        </form>
      </div>
    </div>
    <% }) %>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
function filterPatients() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const rows = document.querySelectorAll('.patient-row');
  let count = 0;
  rows.forEach(r => {
    const match = r.dataset.name.includes(q) || r.dataset.phone.includes(q);
    r.style.display = match ? '' : 'none';
    if(match) count++;
  });
  document.getElementById('searchCount').textContent = count + ' patients';
}
</script>
</body>
</html>
