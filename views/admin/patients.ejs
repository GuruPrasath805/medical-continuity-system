<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin — Patients</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: var(--bg); }
    .admin-topbar {
      background: white; border-bottom: 1px solid var(--border);
      padding: 0.75rem 0; position: sticky; top: 0; z-index: 100;
      box-shadow: 0 1px 0 rgba(0,0,0,0.04);
    }
    .admin-page-header {
      background: linear-gradient(140deg,#052e16,#166534);
      padding: 2rem 0 3.5rem; color: white;
    }
    .admin-content { margin-top: -2rem; position: relative; z-index: 1; }
  </style>
</head>
<body>
<!-- Admin Top Bar -->
<div class="admin-topbar">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="/" style="font-family:'DM Serif Display',serif;font-size:1.2rem;color:var(--green);text-decoration:none;display:flex;align-items:center;gap:8px">
      <svg width="22" height="22" viewBox="0 0 26 26" fill="none"><rect width="26" height="26" rx="7" fill="#16a34a"/><path d="M13 6v14M6 13h14" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
      Medical Continuity
    </a>
    <div class="d-flex align-items-center gap-3">
      <a href="/admin/patients" class="nav-link" style="font-weight:600;color:var(--green)">Patients</a>
      <a href="/admin/doctors"  class="nav-link">Doctors</a>
      <a href="/admin/logout"   class="btn btn-sm btn-outline-primary" style="border-radius:20px;padding:5px 16px">Sign Out</a>
    </div>
  </div>
</div>

<!-- Page Header -->
<div class="admin-page-header">
  <div class="container">
    <span style="font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:0.5">Admin Panel</span>
    <h2 style="font-family:'DM Serif Display',serif;color:white;font-size:2rem;margin-top:4px">Patient Records</h2>
  </div>
</div>

<div class="container admin-content pb-5">
  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-pill">
        <div class="stat-pill-icon">👥</div>
        <div><div class="stat-pill-num"><%= patients.length %></div><div class="stat-pill-lbl">Total Patients</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-pill">
        <div class="stat-pill-icon">📋</div>
        <div><div class="stat-pill-num"><%= patients.filter(p=>p.reports&&p.reports.length>0).length %></div><div class="stat-pill-lbl">With Reports</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-pill">
        <div class="stat-pill-icon">🩸</div>
        <div><div class="stat-pill-num"><%= patients.filter(p=>p.bloodGroup).length %></div><div class="stat-pill-lbl">Blood Group Set</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-pill">
        <div class="stat-pill-icon">📱</div>
        <div><div class="stat-pill-num"><%= patients.filter(p=>p.qrCode).length %></div><div class="stat-pill-lbl">QR Generated</div></div>
      </div>
    </div>
  </div>

  <!-- Table -->
  <% if (patients.length === 0) { %>
    <div class="card-box text-center py-5">
      <div style="font-size:3rem;margin-bottom:12px">👥</div>
      <p style="color:var(--muted)">No patients registered yet.</p>
      <a href="/patient/register" class="btn btn-primary mt-2">Register First Patient</a>
    </div>
  <% } else { %>
  <div class="card-box p-0" style="overflow:hidden">
    <div style="padding:1.2rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
      <h6 style="margin:0;font-weight:700">All Patients <span style="color:var(--muted);font-weight:500">(<%= patients.length %>)</span></h6>
      <a href="/admin/doctors" class="btn btn-outline-primary btn-sm">Manage Doctors →</a>
    </div>
    <div style="overflow-x:auto">
      <table class="table mb-0">
        <thead>
          <tr><th>#</th><th>Patient</th><th>Phone</th><th>Blood</th><th>Emergency</th><th>Registered</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% patients.forEach((p, i) => { %>
          <tr>
            <td class="text-muted" style="font-size:0.82rem"><%= i+1 %></td>
            <td>
              <div class="d-flex align-items-center gap-2">
                <% if(p.photo){ %>
                  <img src="<%= BASE_URL %><%= p.photo %>" style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid var(--green-border)">
                <% } else { %>
                  <div style="width:34px;height:34px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-size:0.9rem">👤</div>
                <% } %>
                <strong style="font-size:0.9rem"><%= p.name %></strong>
              </div>
            </td>
            <td style="font-size:0.88rem"><%= p.phone %></td>
            <td><% if(p.bloodGroup){%><span class="badge-red"><%= p.bloodGroup %></span><%}else{%><span style="color:var(--muted)">—</span><%}%></td>
            <td style="font-size:0.82rem;color:var(--muted)"><%= p.emergencyName %> · <%= p.emergencyContact %></td>
            <td style="font-size:0.8rem;color:var(--muted)"><%= new Date(p.createdAt).toLocaleDateString('en-IN') %></td>
            <td>
              <a href="/admin/patient/<%= p._id %>" class="btn btn-primary btn-sm">View</a>
              <a href="/admin/patient/<%= p._id %>/add-record" class="btn btn-outline-primary btn-sm ms-1">+ Report</a>
              <form method="POST" action="/admin/patient/<%= p._id %>/delete" style="display:inline" onsubmit="return confirm('Remove <%= p.name %> and all their records permanently?')">
                <button type="submit" class="btn btn-sm ms-1" style="background:#fef2f2;color:#b91c1c;border:1px solid #fca5a5;font-weight:600">Remove</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

