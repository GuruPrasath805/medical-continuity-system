<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin — Doctors</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: var(--bg); }
    .admin-topbar { background: white; border-bottom: 1px solid var(--border); padding: 0.75rem 0; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 0 rgba(0,0,0,0.04); }
    .admin-page-header { background: linear-gradient(140deg,#052e16,#166534); padding: 2rem 0 3.5rem; color: white; }
    .admin-content { margin-top: -2rem; position: relative; z-index: 1; }
    .pending-card { background: white; border-radius: var(--radius); border: 1px solid #fde68a; box-shadow: var(--shadow-sm); padding: 1.5rem; transition: all 0.2s; }
    .pending-card:hover { box-shadow: var(--shadow); }
  </style>
</head>
<body>
<div class="admin-topbar">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="/" style="font-family:'DM Serif Display',serif;font-size:1.2rem;color:var(--green);text-decoration:none;display:flex;align-items:center;gap:8px">
      <svg width="22" height="22" viewBox="0 0 26 26" fill="none"><rect width="26" height="26" rx="7" fill="#16a34a"/><path d="M13 6v14M6 13h14" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
      Medical Continuity
    </a>
    <div class="d-flex align-items-center gap-3">
      <a href="/admin/patients" class="nav-link">Patients</a>
      <a href="/admin/doctors"  class="nav-link" style="font-weight:600;color:var(--green)">Doctors</a>
      <a href="/admin/logout" class="btn btn-sm btn-outline-primary" style="border-radius:20px;padding:5px 16px">Sign Out</a>
    </div>
  </div>
</div>

<div class="admin-page-header">
  <div class="container">
    <span style="font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;opacity:0.5">Admin Panel</span>
    <h2 style="font-family:'DM Serif Display',serif;color:white;font-size:2rem;margin-top:4px">Doctor Management</h2>
  </div>
</div>

<div class="container admin-content pb-5">

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-pill">
        <div class="stat-pill-icon">✅</div>
        <div><div class="stat-pill-num"><%= approved.length %></div><div class="stat-pill-lbl">Approved</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-pill">
        <div class="stat-pill-icon" style="background:#fffbeb">⏳</div>
        <div><div class="stat-pill-num"><%= pending.length %></div><div class="stat-pill-lbl">Pending</div></div>
      </div>
    </div>
  </div>

  <!-- Pending -->
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h6 style="margin:0;font-weight:700;font-size:0.88rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted)">Pending Applications</h6>
    <% if(pending.length>0){ %><span class="badge-yellow"><%= pending.length %> awaiting review</span><% } %>
  </div>

  <% if(pending.length===0){ %>
    <div class="card-box text-center py-4 mb-4" style="border-style:dashed">
      <p class="text-muted mb-0" style="font-size:0.88rem">No pending applications right now.</p>
    </div>
  <% } else { %>
    <div class="row g-3 mb-4">
      <% pending.forEach(doc=>{ %>
      <div class="col-md-6">
        <div class="pending-card">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div class="d-flex align-items-center gap-3">
              <div style="width:44px;height:44px;background:var(--green-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem">👨‍⚕️</div>
              <div>
                <h6 style="margin:0;font-weight:700"><%= doc.name %></h6>
                <small style="color:var(--muted)"><%= doc.email %></small>
              </div>
            </div>
            <span class="badge-yellow">Pending</span>
          </div>
          <% if(doc.license){ %>
            <a href="<%= doc.license %>" target="_blank" class="btn btn-outline-primary btn-sm w-100 mb-3">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:5px;margin-top:-2px"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              View License Document
            </a>
          <% } %>
          <div class="d-flex gap-2">
            <form method="POST" action="/admin/doctors/approve/<%= doc._id %>" style="flex:1">
              <button type="submit" class="btn btn-success w-100">✓ Approve</button>
            </form>
            <form method="POST" action="/admin/doctors/reject/<%= doc._id %>" style="flex:1" onsubmit="return confirm('Reject and permanently delete this application?')">
              <button type="submit" class="btn btn-danger w-100">✗ Reject</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Approved -->
  <div class="d-flex align-items-center justify-content-between mb-3 mt-2">
    <h6 style="margin:0;font-weight:700;font-size:0.88rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted)">Approved Doctors</h6>
  </div>

  <% if(approved.length===0){ %>
    <div class="card-box text-center py-4" style="border-style:dashed">
      <p class="text-muted mb-0" style="font-size:0.88rem">No approved doctors yet.</p>
    </div>
  <% } else { %>
    <div class="card-box p-0" style="overflow:hidden">
      <div style="overflow-x:auto">
        <table class="table mb-0">
          <thead>
            <tr><th>Doctor</th><th>Email</th><th>License</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% approved.forEach(doc=>{ %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div style="width:34px;height:34px;background:var(--green-light);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.95rem">👨‍⚕️</div>
                  <strong style="font-size:0.9rem"><%= doc.name %></strong>
                </div>
              </td>
              <td style="font-size:0.85rem;color:var(--muted)"><%= doc.email %></td>
              <td>
                <% if(doc.license){ %>
                  <a href="<%= doc.license %>" target="_blank" class="btn btn-outline-primary btn-sm">View</a>
                <% } else { %>
                  <span style="color:var(--muted);font-size:0.82rem">—</span>
                <% } %>
              </td>
              <td><span class="badge-green">Active</span></td>
              <td>
                <form method="POST" action="/admin/doctors/remove/<%= doc._id %>" onsubmit="return confirm('Remove Dr. <%= doc.name %>? This cannot be undone.')">
                  <button type="submit" class="btn btn-sm" style="background:#fef2f2;color:#b91c1c;border:1px solid #fca5a5;font-weight:600">Remove</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

