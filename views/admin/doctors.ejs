<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin — Doctor Management</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body{background:#f8fafc}
    .admin-topbar{background:white;border-bottom:1px solid #e5e7eb;padding:.75rem 0;position:sticky;top:0;z-index:100;box-shadow:0 1px 0 rgba(0,0,0,.04)}
    .page-hero{background:linear-gradient(135deg,#052e16,#14532d 55%,#166534);padding:2rem 0 4rem;color:white;position:relative;overflow:hidden}
    .pull-up{margin-top:-2.5rem;position:relative;z-index:2}
    .stat-box{background:white;border:1px solid #e5e7eb;border-radius:16px;padding:1.2rem 1.4rem;box-shadow:0 2px 8px rgba(0,0,0,.05);display:flex;align-items:center;gap:1rem}
    .stat-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
    .stat-num{font-size:1.7rem;font-weight:800;color:#111827;font-family:'JetBrains Mono',monospace;line-height:1}
    .stat-lbl{font-size:.72rem;color:#9ca3af;font-weight:700;margin-top:3px}

    /* section card */
    .section-card{background:white;border:1px solid #e5e7eb;border-radius:16px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04);margin-bottom:1.5rem}
    .section-head{padding:.9rem 1.4rem;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between}
    .section-title{font-size:.82rem;font-weight:800;color:#111827;display:flex;align-items:center;gap:8px}
    .count-badge{background:#f1f5f9;border-radius:20px;padding:2px 10px;font-size:.72rem;font-weight:700;color:#64748b}
    .pending-badge{background:#fffbeb;border:1px solid #fde68a;border-radius:20px;padding:2px 10px;font-size:.72rem;font-weight:700;color:#92400e}
    .approved-badge{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;padding:2px 10px;font-size:.72rem;font-weight:700;color:#166534}

    /* doctor rows */
    .doc-row{display:grid;grid-template-columns:1fr 1fr auto;gap:1rem;padding:.9rem 1.4rem;border-bottom:1px solid #f3f4f6;align-items:center;transition:background .15s}
    .doc-row:last-child{border-bottom:none}
    .doc-row:hover{background:#fafafa}
    .doc-avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#e0f2fe,#bae6fd);border:2px solid #bae6fd;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
    .doc-name{font-weight:700;font-size:.88rem;color:#111827}
    .doc-email{font-size:.72rem;color:#9ca3af;margin-top:1px}
    .doc-license a{font-size:.75rem;color:#2563eb;text-decoration:none;font-weight:600;display:flex;align-items:center;gap:4px}
    .doc-license a:hover{color:#1d4ed8;text-decoration:underline}
    .action-grp{display:flex;gap:.4rem}
    .btn-approve{background:#16a34a;color:white;border:none;border-radius:8px;padding:5px 14px;font-size:.75rem;font-weight:700;cursor:pointer;transition:all .18s}
    .btn-approve:hover{background:#15803d;transform:translateY(-1px)}
    .btn-reject{background:#fef2f2;color:#b91c1c;border:1px solid #fecaca;border-radius:8px;padding:5px 12px;font-size:.75rem;font-weight:700;cursor:pointer;transition:all .15s}
    .btn-reject:hover{background:#fee2e2}
    .btn-remove{background:#fef2f2;color:#b91c1c;border:1px solid #fecaca;border-radius:8px;padding:5px 12px;font-size:.75rem;font-weight:700;cursor:pointer;transition:all .15s}
    .btn-remove:hover{background:#fee2e2}
    .verified-chip{display:inline-flex;align-items:center;gap:4px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700;color:#166534}
    .empty-row{padding:2.5rem;text-align:center;color:#9ca3af;font-size:.88rem}

    @media(max-width:768px){.doc-row{grid-template-columns:1fr;gap:.5rem}}
  </style>
</head>
<body>

<!-- TOP BAR -->
<div class="admin-topbar">
  <div class="container d-flex align-items-center justify-content-between">
    <a href="/" style="font-family:'DM Serif Display',serif;font-size:1.2rem;color:var(--green);text-decoration:none;display:flex;align-items:center;gap:8px">
      <svg width="22" height="22" viewBox="0 0 26 26" fill="none"><rect width="26" height="26" rx="7" fill="#16a34a"/><path d="M13 6v14M6 13h14" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
      Medical Continuity
    </a>
    <div class="d-flex align-items-center gap-3">
      <a href="/admin/patients" class="nav-link" style="font-size:.85rem">Patients</a>
      <a href="/admin/doctors"  class="nav-link" style="font-weight:700;color:var(--green);font-size:.85rem">Doctors</a>
      <a href="/admin/logout" class="btn btn-sm btn-outline-primary" style="border-radius:20px;padding:5px 16px;font-size:.82rem">Sign Out</a>
    </div>
  </div>
</div>

<!-- HERO -->
<div class="page-hero">
  <div class="container">
    <div style="font-size:.7rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.4rem">Admin Panel</div>
    <h2 style="font-family:'DM Serif Display',serif;color:white;font-size:2rem;margin:0">Doctor Management</h2>
    <p style="color:rgba(255,255,255,.45);font-size:.85rem;margin-top:4px">Review, approve and manage doctor registrations</p>
  </div>
</div>

<div class="container pull-up pb-5">

  <!-- STATS -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#f0fdf4">✅</div>
        <div><div class="stat-num"><%= approved.length %></div><div class="stat-lbl">Approved Doctors</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#fffbeb">⏳</div>
        <div><div class="stat-num"><%= pending.length %></div><div class="stat-lbl">Pending Review</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#eff6ff">👨‍⚕️</div>
        <div><div class="stat-num"><%= approved.length + pending.length %></div><div class="stat-lbl">Total Registered</div></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-box">
        <div class="stat-icon" style="background:#fef2f2">📧</div>
        <div><div class="stat-num"><%= pending.length > 0 ? pending.length : '0' %></div><div class="stat-lbl">Awaiting Action</div></div>
      </div>
    </div>
  </div>

  <!-- PENDING -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Pending Approval
      </div>
      <span class="pending-badge"><%= pending.length %> awaiting</span>
    </div>

    <% if(pending.length === 0){ %>
      <div class="empty-row">
        <div style="font-size:1.8rem;margin-bottom:6px">✅</div>
        <p style="margin:0">No pending requests — all doctors have been reviewed.</p>
      </div>
    <% } else { %>
      <% pending.forEach(d => { %>
      <div class="doc-row">
        <div style="display:flex;align-items:center;gap:10px">
          <div class="doc-avatar">👨‍⚕️</div>
          <div>
            <div class="doc-name">Dr. <%= d.name %></div>
            <div class="doc-email"><%= d.email %></div>
          </div>
        </div>
        <div class="doc-license">
          <% if(d.license){ %>
            <a href="<%= BASE_URL %><%= d.license %>" target="_blank">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              View License
            </a>
          <% } else { %>
            <span style="color:#c4c9d4;font-size:.78rem">No license uploaded</span>
          <% } %>
        </div>
        <div class="action-grp">
          <form method="POST" action="/admin/doctors/approve/<%= d._id %>" style="display:inline">
            <button type="submit" class="btn-approve">✓ Approve</button>
          </form>
          <form method="POST" action="/admin/doctors/reject/<%= d._id %>" style="display:inline" onsubmit="return confirm('Reject Dr. <%= d.name %>?')">
            <button type="submit" class="btn-reject">✕ Reject</button>
          </form>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

  <!-- APPROVED -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        Approved Doctors
      </div>
      <span class="approved-badge"><%= approved.length %> verified</span>
    </div>

    <% if(approved.length === 0){ %>
      <div class="empty-row">
        <div style="font-size:1.8rem;margin-bottom:6px">👨‍⚕️</div>
        <p style="margin:0">No approved doctors yet.</p>
      </div>
    <% } else { %>
      <% approved.forEach(d => { %>
      <div class="doc-row">
        <div style="display:flex;align-items:center;gap:10px">
          <div class="doc-avatar" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);border-color:#bbf7d0">👨‍⚕️</div>
          <div>
            <div class="doc-name">Dr. <%= d.name %></div>
            <div class="doc-email"><%= d.email %></div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:.75rem">
          <span class="verified-chip">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Verified
          </span>
          <% if(d.license){ %>
            <a href="<%= BASE_URL %><%= d.license %>" target="_blank" style="font-size:.75rem;color:#2563eb;font-weight:600;text-decoration:none">View License</a>
          <% } %>
        </div>
        <div class="action-grp">
          <form method="POST" action="/admin/doctors/remove/<%= d._id %>" style="display:inline" onsubmit="return confirm('Remove Dr. <%= d.name %>?')">
            <button type="submit" class="btn-remove">Remove</button>
          </form>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
