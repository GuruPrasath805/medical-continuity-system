<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Doctor Login — Medical Continuity</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: var(--bg); }
    .split-layout { min-height: 100vh; display: flex; }
    .split-left {
      flex: 0 0 42%; background: linear-gradient(145deg,#052e16,#166534);
      display: flex; flex-direction: column; justify-content: center;
      padding: 4rem 3rem; position: relative; overflow: hidden;
    }
    .split-left::after {
      content:''; position:absolute; top:-100px; right:-100px;
      width:300px; height:300px; border-radius:50%;
      background:radial-gradient(circle,rgba(74,222,128,0.1) 0%,transparent 70%);
    }
    .split-right {
      flex: 1; display: flex; align-items: center; justify-content: center;
      padding: 2rem;
    }
    .login-card { width: 100%; max-width: 420px; }
    @media(max-width:768px){ .split-left{display:none} }
  </style>
</head>
<body>
<%- include('../partials/navbar') %>
<div class="split-layout">
  <!-- Left Panel -->
  <div class="split-left">
    <div style="position:relative;z-index:1">
      <div style="width:56px;height:56px;background:rgba(255,255,255,0.1);border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:2rem">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <h2 style="font-family:'DM Serif Display',serif;color:white;font-size:2.2rem;margin-bottom:1rem">Doctor Portal</h2>
      <p style="color:rgba(255,255,255,0.65);font-size:0.92rem;line-height:1.75;max-width:300px">Access patient medical records securely. OTP verification ensures consent before viewing any record.</p>
      <div style="margin-top:2.5rem;display:flex;flex-direction:column;gap:12px">
        <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,0.65);font-size:0.85rem">
          <div style="width:28px;height:28px;background:rgba(255,255,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">✓</div>
          Admin-approved access only
        </div>
        <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,0.65);font-size:0.85rem">
          <div style="width:28px;height:28px;background:rgba(255,255,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">✓</div>
          OTP consent per patient session
        </div>
        <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,0.65);font-size:0.85rem">
          <div style="width:28px;height:28px;background:rgba(255,255,255,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">✓</div>
          Complete medical history access
        </div>
      </div>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="split-right">
    <div class="login-card">
      <h3 style="font-family:'DM Serif Display',serif;font-size:1.9rem;margin-bottom:0.25rem">Sign in</h3>
      <p style="color:var(--muted);font-size:0.88rem;margin-bottom:2rem">Enter your registered doctor credentials</p>

      <% if (error) { %><div class="alert-danger mb-4"><%= error %></div><% } %>

      <form method="POST" action="/doctor/login">
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="doctor@hospital.com" required>
        </div>
        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
        </div>
        <button type="submit" class="btn btn-primary w-100 btn-lg">Sign In to Portal</button>
      </form>

      <div style="text-align:center;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border)">
        <p style="font-size:0.85rem;color:var(--muted)">
          New doctor? <a href="/doctor/register" style="color:var(--green);font-weight:600">Apply for access →</a>
        </p>
        <a href="/" style="font-size:0.82rem;color:var(--muted)">← Back to home</a>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
