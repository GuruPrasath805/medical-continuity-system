<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Doctor Registration - Medical Continuity</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: #f8faf8; }
    .reg-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
    .reg-card { background: white; border-radius: 20px; box-shadow: 0 8px 40px rgba(0,0,0,.1); overflow: hidden; width: 100%; max-width: 560px; }
    .reg-head { background: linear-gradient(135deg,#052e16,#166534); padding: 2rem; color: white; text-align: center; }
    .reg-head h2 { font-family: 'DM Serif Display',serif; font-size: 1.7rem; margin-bottom: 4px; }
    .reg-head p { font-size: .85rem; color: rgba(255,255,255,.6); margin: 0; }
    .reg-body { padding: 2rem; }
    .form-label { font-size: .78rem; font-weight: 700; color: #374151; margin-bottom: 5px; }
    .form-control { border: 1.5px solid #e5e7eb; border-radius: 10px; padding: .65rem 1rem; font-size: .9rem; transition: all .2s; }
    .form-control:focus { border-color: #16a34a; box-shadow: 0 0 0 4px rgba(22,163,74,.1); outline: none; }
    .sec-title { font-size: .65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: #9ca3af; margin: 1.5rem 0 .75rem; padding-bottom: .5rem; border-bottom: 1px solid #f3f4f6; }
    .photo-preview { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #bbf7d0; display: none; }
    .photo-placeholder { width: 80px; height: 80px; border-radius: 50%; background: #f0fdf4; border: 2px dashed #bbf7d0; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; cursor: pointer; }
    .upload-zone { display: flex; align-items: center; gap: 1rem; }
    .upload-hint { font-size: .75rem; color: #9ca3af; }
    .btn-register { background: #16a34a; color: white; border: none; border-radius: 10px; padding: .8rem; font-size: .95rem; font-weight: 700; width: 100%; cursor: pointer; transition: all .2s; margin-top: 1rem; }
    .btn-register:hover { background: #15803d; }
    .err-box { background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: .75rem 1rem; font-size: .85rem; color: #b91c1c; margin-bottom: 1rem; }
    .login-link { text-align: center; margin-top: 1.2rem; font-size: .85rem; color: #6b7280; }
    .login-link a { color: #16a34a; font-weight: 700; text-decoration: none; }
    .info-note { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: .65rem 1rem; font-size: .78rem; color: #166534; margin-top: .5rem; }
  </style>
</head>
<body>
<%- include('../partials/navbar') %>
<div class="reg-wrap">
  <div class="reg-card">
    <div class="reg-head">
      <h2>Doctor Registration</h2>
      <p>Create your account to access patient records securely</p>
    </div>
    <div class="reg-body">
      <% if(error){ %><div class="err-box"><%= error %></div><% } %>

      <form method="POST" action="/doctor/register" enctype="multipart/form-data">

        <div class="sec-title">Profile Photo</div>
        <div class="upload-zone mb-3">
          <div>
            <img id="photoPreview" class="photo-preview" src="">
            <div class="photo-placeholder" id="photoPlaceholder" onclick="document.getElementById('photoInput').click()">+</div>
          </div>
          <div>
            <input type="file" name="photo" id="photoInput" accept="image/*" style="display:none" onchange="previewPhoto(this)">
            <button type="button" onclick="document.getElementById('photoInput').click()" style="background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;border-radius:8px;padding:6px 16px;font-size:.82rem;font-weight:700;cursor:pointer">Choose Photo</button>
            <div class="upload-hint mt-1">JPG or PNG, max 5MB</div>
          </div>
        </div>

        <div class="sec-title">Personal Information</div>
        <div class="mb-3">
          <label class="form-label">Full Name *</label>
          <input type="text" name="name" class="form-control" placeholder="Dr. Your Name" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Hospital / Clinic Name</label>
          <input type="text" name="hospitalName" class="form-control" placeholder="Apollo Hospital, Chennai">
        </div>

        <div class="sec-title">Account Details</div>
        <div class="mb-3">
          <label class="form-label">Email Address *</label>
          <input type="email" name="email" class="form-control" placeholder="doctor@hospital.com" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Password *</label>
          <input type="password" name="password" class="form-control" placeholder="Min 6 characters" required minlength="6">
        </div>

        <div class="sec-title">Medical License</div>
        <div class="mb-3">
          <label class="form-label">License Document (PDF or Image)</label>
          <input type="file" name="license" class="form-control" accept=".pdf,.jpg,.jpeg,.png">
          <div class="info-note">Upload your medical license for admin verification. Your account will be approved after review.</div>
        </div>

        <button type="submit" class="btn-register">Submit Registration</button>
      </form>

      <div class="login-link">Already registered? <a href="/doctor/login">Sign In</a></div>
    </div>
  </div>
</div>

<script>
function previewPhoto(input) {
  if (input.files && input.files[0]) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var preview = document.getElementById('photoPreview');
      var placeholder = document.getElementById('photoPlaceholder');
      preview.src = e.target.result;
      preview.style.display = 'block';
      placeholder.style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>
</body>
</html>
