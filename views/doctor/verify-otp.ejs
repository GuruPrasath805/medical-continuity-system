<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Verify OTP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card-box">
        <div class="text-center mb-4">
          <div style="font-size:3rem"></div>
          <h3 style="color:var(--green);font-weight:800">Verify OTP</h3>
          <p class="text-muted small">OTP sent to patient: <strong><%= phone %></strong><% if(patientName){ %> (<%= patientName %>)<% } %></p>
        </div>

        <% if (smsSent) { %>
          <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:1rem;margin-bottom:1rem;text-align:center">
            <div style="font-size:1.5rem;margin-bottom:4px"></div>
            <div style="font-weight:700;color:#166534;font-size:.9rem">OTP sent via SMS</div>
            <div style="font-size:.82rem;color:#6b7280;margin-top:2px">Sent to emergency contact number</div>
          </div>
        <% } else { %>
          <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:1rem;margin-bottom:1rem;text-align:center">
            <div style="font-size:1.5rem;margin-bottom:4px"></div>
            <div style="font-weight:700;color:#92400e;font-size:.9rem">OTP Generated</div>
            <div style="font-size:.82rem;color:#6b7280;margin-top:2px">Check your terminal for the OTP code</div>
          </div>
        <% } %>
        <% if (error) { %><div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:.75rem 1rem;margin-bottom:1rem;font-size:.85rem;color:#b91c1c"><%= error %></div><% } %>

        <form method="POST" action="/doctor/verify-otp">
          <input type="hidden" name="phone" value="<%= phone %>">
          <div class="mb-3">
            <label class="form-label">Enter 6-Digit OTP</label>
            <input type="text" name="otp" class="form-control text-center"
              maxlength="6" pattern="\d{6}" placeholder="     "
              style="font-size:1.8rem;letter-spacing:10px;font-weight:700" required autofocus>
          </div>
          <button type="submit" class="btn btn-primary w-100">Verify & View Full Records</button>
        </form>
        <p class="text-center mt-3"><a href="/doctor/dashboard" class="text-muted small">&larr; Back to Dashboard</a></p>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
