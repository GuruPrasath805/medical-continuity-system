<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Health ID Created — Medical Continuity</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">

  <style>
    body { background:#f8fafc; }
    .success-wrap { min-height:calc(100vh - 64px); display:flex; align-items:flex-start; justify-content:center; padding:3rem 1rem; }
    .success-inner { width:100%; max-width:720px; }

    .hid-card {
      background:white; border:1px solid #e5e7eb; border-radius:20px;
      padding:2rem; box-shadow:0 8px 40px rgba(0,0,0,.09);
    }

    .hid-body { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:20px; }

    .hid-photo {
      width:80px; height:80px; border-radius:50%;
      object-fit:cover; border:2px solid #e5e7eb;
    }

    .hid-photo-ph {
      width:80px; height:80px; border-radius:50%;
      background:#f3f4f6; display:flex; align-items:center; justify-content:center;
      font-size:1.5rem;
    }

    .hid-name { font-size:1.5rem; font-weight:bold; margin-top:10px; }

    .hid-qr-box {
      background:#f8fafc;
      border:1.5px solid #e5e7eb;
      border-radius:12px;
      padding:10px;
    }

    .hid-qr-box img {
      width:120px;
      height:120px;
    }

    .act-btn {
      display:inline-block;
      padding:10px 20px;
      background:#16a34a;
      color:white;
      border-radius:10px;
      text-decoration:none;
      font-weight:bold;
      margin-top:20px;
    }
  </style>
</head>

<body>

<%- include('../partials/navbar') %>

<div class="success-wrap">
  <div class="success-inner">

    <h2 style="margin-bottom:20px;">✅ Health ID Created Successfully</h2>

    <div class="hid-card">

      <div class="hid-body">

        <!-- LEFT SIDE -->
        <div>

          <!-- PHOTO FIX -->
          <% if (patient.photo) { %>
            <img src="<%= patient.photo %>" class="hid-photo" alt="Photo"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="hid-photo-ph" style="display:none">👤</div>
          <% } else { %>
            <div class="hid-photo-ph">👤</div>
          <% } %>

          <div class="hid-name"><%= patient.name %></div>

          <p><strong>Phone:</strong> <%= patient.phone %></p>
          <p><strong>Blood Group:</strong> <%= patient.bloodGroup || '-' %></p>

        </div>

        <!-- RIGHT SIDE QR FIX -->
        <% if (patient.qrCode) { %>
        <div class="hid-qr-box">
          <img src="<%= patient.qrCode %>" alt="QR Code"
               onerror="this.style.display='none'; this.parentElement.innerHTML='QR not found';">
        </div>
        <% } %>

      </div>

      <!-- DOWNLOAD BUTTON FIX -->
      <% if (patient.qrCode) { %>
        <a href="<%= patient.qrCode %>" download class="act-btn">
          Download QR
        </a>
      <% } %>

    </div>

  </div>
</div>

<%- include('../partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>